---
import Base from "../layouts/Base.astro";
---

<Base
  title="Not found"
  description="That page is not available on Marc Kayrouz's site."
>
  <section class="wrap hero">
    <div class="hero__copy">
      <span class="eyebrow">404</span>
      <h1>Nothing useful at this address.</h1>
      <p class="lede" style="margin-top: 1.25rem;">
        The page may have moved, or I may have overestimated my own routing discipline. Try the
        <a href="/">home page</a>, or jump to
        <a href="/work">work</a> or
        <a href="/experience">experience</a>.
      </p>
    </div>

    <aside class="hero__panel" aria-label="Useful links">
      <span class="hero__panel-title">Useful links</span>
      <ul class="hero__panel-list">
        <li><a href="/">About Marc Kayrouz</a></li>
        <li><a href="/work">Selected work</a></li>
        <li><a href="/experience">Experience</a></li>
      </ul>
    </aside>
  </section>
</Base>
