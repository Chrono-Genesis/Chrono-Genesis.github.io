---
import Base from "../layouts/Base.astro";

const featuredWork = [
  {
    title: "Mobile driver's license, from standard to store release",
    year: "2024–2025",
    body: "Led the mobile side of Colorado's mDL work: identity proofing, liveness, issuance, presentation, secure state, and recovery after redirects or app restarts.",
  },
  {
    title: "Crash-free user rate from 98% to 99.99%",
    year: "2022–2024",
    body: "Moved reliability from a metric people checked after release into a gate the team uses while traffic is still ramping. Crashlytics now helps decide when to widen, hold, or dig in.",
  },
  {
    title: "Shared mobile core without a rewrite pause",
    year: "2025–",
    body: "Started the Kotlin Multiplatform layer for business rules shared by both apps. iOS consumes an XCFramework; Android consumes a Maven AAR; both are packaged through Azure.",
  },
];

const availableFor = [
  {
    title: "Lead a small mobile team",
    body: "Set architecture, review work, keep iOS and Android aligned, and still write code.",
  },
  {
    title: "Identity and credential flows",
    body: "OAuth, proofing, liveness, secure storage, redirects, vendor SDKs, and clear error states.",
  },
  {
    title: "Modernize an existing app",
    body: "Move screens and shared code toward SwiftUI, Jetpack Compose, Kotlin, or KMP while features keep shipping.",
  },
  {
    title: "Release and developer tooling",
    body: "Build pipelines, fastlane, Azure DevOps, release gates, and internal tools for developers and QA.",
  },
];
---

<Base
  title="Marc Kayrouz"
  description="Marc Kayrouz builds iOS and Android systems for digital identity, mobile credentials, release reliability, and app modernization."
>
  <section class="wrap hero">
    <div class="hero__copy">
      <h1 class="hero__name">Marc Kayrouz</h1>
      <p class="hero__role">iOS and Android architecture for public-service apps.</p>

      <p class="hero__lede">
        At Colorado OIT, I lead iOS and Android architecture for
        <a href="https://mycolorado.gov" rel="noopener">myColorado</a>, the State of Colorado's
        official citizen app for digital driver's licenses, vehicle registration, licenses,
        health records, and other state services. Most of my work is in identity, credentials,
        release reliability, and older app code that still has to keep moving.
      </p>

      <p class="hero__lede">
        The app is not small: about 2M downloads, 610k monthly active users, and 4.8 stars
        across 144,000+ ratings. The mobile team is small: three developers and three QA
        engineers. I stay close to the code, mentor the iOS and Android developers beside me,
        and cross into AWS Lambda or legacy PHP when a mobile feature depends on it.
      </p>

      <dl class="hero__meta">
        <div>
          <dt>Role</dt>
          <dd>Principal Developer · State of Colorado · OIT</dd>
        </div>
        <div>
          <dt>Based</dt>
          <dd>Greater Denver, CO · Remote</dd>
        </div>
        <div>
          <dt>Core</dt>
          <dd>Swift · Kotlin · Python</dd>
        </div>
        <div>
          <dt>Reach</dt>
          <dd>
            <a href="mailto:marc_kayrouz@protonmail.com">Email</a>,
            <a href="https://www.linkedin.com/in/marc-kayrouz-7a953735" rel="me noopener" target="_blank">LinkedIn</a>
          </dd>
        </div>
      </dl>
    </div>

    <aside class="hero__panel" aria-label="Current focus">
      <span class="hero__panel-title">Current focus</span>
      <ul class="hero__panel-list">
        <li>Mobile driver's license and verifiable credentials in production</li>
        <li>Release gates that catch trouble while rollout can still change</li>
        <li>Shared mobile logic that keeps two native apps from drifting apart</li>
        <li>SwiftUI and Jetpack Compose migration without freezing product work</li>
      </ul>
    </aside>
  </section>

  <section class="wrap section section--panel">
    <span class="eyebrow">Selected work</span>
    <ul class="work-list">
      {
        featuredWork.map((w) => (
          <li>
            <article class="work">
              <header class="work__head">
                <h2 class="work__title">{w.title}</h2>
                <span class="work__year">{w.year}</span>
              </header>
              <p class="work__body">{w.body}</p>
            </article>
          </li>
        ))
      }
    </ul>
    <p style="margin-top: 2.5rem;">
      <a href="/work">Read the work notes →</a>
    </p>
  </section>

  <section class="wrap section">
    <span class="eyebrow">How I work</span>
    <p>
      On a small team, process has to earn its place. I prefer small PRs, named owners,
      written decisions, and release checks that happen before a rollout reaches everyone.
      Before I add a dependency or a new pattern, I want to know who will maintain it six
      months from now.
    </p>
    <p>
      For mobile ID work, I also watch adjacent rollouts like CA DMV Wallet, LA Wallet, and
      Apple Wallet ID integrations. Standards are moving quickly; I would rather change a
      design on paper than migrate the wrong primitive after release.
    </p>
  </section>

  <section class="wrap section section--panel">
    <span class="eyebrow">Available for</span>
    <p class="lede" style="margin-bottom: 1.5rem;">
      Contract and freelance work where the mobile app is already important, already in
      production, or about to take on identity or release risk.
    </p>
    <ul class="work-list">
      {
        availableFor.map((fit) => (
          <li>
            <article class="work">
              <h2 class="work__title">{fit.title}</h2>
              <p class="work__body">{fit.body}</p>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
