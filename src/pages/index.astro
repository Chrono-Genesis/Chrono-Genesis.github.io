---
import Base from "../layouts/Base.astro";

const featuredWork = [
  {
    title: "Mobile driver's license, from standard to store release",
    year: "2024–2025",
    body: "Led the mobile side of Colorado's mDL work: identity proofing, liveness, issuance, presentation, secure state, and all the small recovery paths that make a standards-heavy flow feel like one product.",
  },
  {
    title: "Crash-free user rate from 98% to 99.99%",
    year: "2022–2024",
    body: "Moved reliability from a metric people checked after release into a gate the team uses while traffic is still ramping. Crashlytics now helps decide when to widen, hold, or dig in.",
  },
  {
    title: "Shared mobile core without a rewrite pause",
    year: "2025–",
    body: "Started the Kotlin Multiplatform layer where duplication was beginning to cost more than coordination: business logic, packaged for iOS and Android through Azure, with local overrides that keep daily development practical.",
  },
];

const goodFits = [
  {
    title: "Fractional mobile lead",
    body: "Useful when a team needs senior direction across iOS and Android, but still needs the person setting direction to understand the code.",
  },
  {
    title: "Identity and credential flows",
    body: "OAuth, proofing, liveness, secure storage, redirects, vendor SDKs, and the recovery states that decide whether users trust the flow.",
  },
  {
    title: "Modernization without a freeze",
    body: "Moving toward SwiftUI, Jetpack Compose, Kotlin, and shared business logic while roadmap work keeps shipping.",
  },
  {
    title: "Release and developer tooling",
    body: "CI/CD, fastlane, Azure DevOps, release gates, and internal tools that make build, QA, and rollout work less dependent on tribal memory.",
  },
];
---

<Base
  title="Marc Kayrouz"
  description="Marc Kayrouz builds citizen-scale mobile systems: digital identity, crash-free release gates, native architecture, and steady modernization across iOS and Android."
>
  <section class="wrap hero">
    <div class="hero__copy">
      <h1 class="hero__name">Marc Kayrouz</h1>
      <p class="hero__role">Mobile architecture for apps people have to trust.</p>

      <p class="hero__lede">
        I build the parts of mobile apps that need to be calm under pressure: identity,
        credentials, release discipline, and old code that still has people depending on it.
        At Colorado OIT, I lead iOS and Android architecture for
        <a href="https://mycolorado.gov" rel="noopener">myColorado</a>, the State of Colorado's
        official citizen app for digital driver's licenses, vehicle registration, licenses,
        health records, and other state services.
      </p>

      <p class="hero__lede">
        The app is not small: about 2M downloads, 610k monthly active users, and 4.8 stars
        across 144,000+ ratings. The mobile team is small: three developers and three QA
        engineers. I stay close to the code, mentor the iOS and Android developers beside me,
        and cross into AWS Lambda or legacy PHP when the work refuses to stay neatly mobile.
      </p>

      <dl class="hero__meta">
        <div>
          <dt>Role</dt>
          <dd>Principal Developer · State of Colorado · OIT</dd>
        </div>
        <div>
          <dt>Based</dt>
          <dd>Greater Denver, CO · Remote</dd>
        </div>
        <div>
          <dt>Core</dt>
          <dd>Swift · Kotlin · Python</dd>
        </div>
        <div>
          <dt>Reach</dt>
          <dd>
            <a href="mailto:marc_kayrouz@protonmail.com">Email</a>,
            <a href="https://www.linkedin.com/in/marc-kayrouz-7a953735" rel="me noopener" target="_blank">LinkedIn</a>
          </dd>
        </div>
      </dl>
    </div>

    <aside class="hero__panel" aria-label="Current focus">
      <span class="hero__panel-title">Current focus</span>
      <ul class="hero__panel-list">
        <li>Mobile driver's license and verifiable credentials in production</li>
        <li>Release gates that catch trouble while rollout can still change</li>
        <li>Shared mobile logic that keeps two native apps from drifting apart</li>
        <li>SwiftUI and Jetpack Compose migration without freezing product work</li>
      </ul>
    </aside>
  </section>

  <section class="wrap section section--panel">
    <span class="eyebrow">Selected work</span>
    <ul class="work-list">
      {
        featuredWork.map((w) => (
          <li>
            <article class="work">
              <header class="work__head">
                <h2 class="work__title">{w.title}</h2>
                <span class="work__year">{w.year}</span>
              </header>
              <p class="work__body">{w.body}</p>
            </article>
          </li>
        ))
      }
    </ul>
    <p style="margin-top: 2.5rem;">
      <a href="/work">Read the work notes →</a>
    </p>
  </section>

  <section class="wrap section">
    <span class="eyebrow">How I work</span>
    <p>
      I am most useful where product pressure and platform risk are in the same room. I like
      small PRs, plain architecture, named owners, written decisions, and migration plans that
      survive normal sprint pressure. My default question is: will this make the next change
      easier to understand, test, and recover from?
    </p>
    <p>
      For mobile ID work, I also watch adjacent rollouts like CA DMV Wallet, LA Wallet, and
      Apple Wallet ID integrations as field notes. Standards are moving quickly, and the
      cheapest mistake to fix is the one you avoid before it becomes part of the app's shape.
    </p>
  </section>

  <section class="wrap section section--panel">
    <span class="eyebrow">Good fits</span>
    <p class="lede" style="margin-bottom: 1.5rem;">
      The Gun.io version is simple: mobile engineer, solutions architect, Swift, Kotlin,
      Python. The more useful version is where I tend to help most.
    </p>
    <ul class="work-list">
      {
        goodFits.map((fit) => (
          <li>
            <article class="work">
              <h2 class="work__title">{fit.title}</h2>
              <p class="work__body">{fit.body}</p>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
