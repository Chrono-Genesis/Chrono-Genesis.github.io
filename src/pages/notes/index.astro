---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const isProd = import.meta.env.PROD;

const notes = (await getCollection("notes", ({ data }) => isProd ? !data.draft : true))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
});
---

<Base
  title="Notes"
  description="Short notes from Marc Kayrouz on reliable mobile systems, digital identity, release gates, modernization, and architecture under production pressure."
>
  <section class="wrap hero">
    <div class="hero__copy">
      <span class="eyebrow">Notes</span>
      <h1>Notes</h1>
      <p class="lede" style="margin-top: 1.25rem;">
        The decisions behind the neat one-line metrics: how to modernize without pausing
        roadmap work, how release gates survive pressure, and why identity systems usually
        need less cleverness than patience.
      </p>
    </div>

    <aside class="hero__panel" aria-label="Writing topics">
      <span class="hero__panel-title">Topics</span>
      <ul class="hero__panel-list">
        <li>Mobile architecture under production pressure</li>
        <li>Digital identity details that affect user trust</li>
        <li>Migrations, release gates, and small habits that compound</li>
      </ul>
    </aside>
  </section>

  <section class="wrap section section--panel">
    {
      notes.length === 0 ? (
        <div class="empty-state">No posts yet. Soon.</div>
      ) : (
        <ul class="notes-list">
          {notes.map((n) => (
            <li class="note-card">
              <a href={`/notes/${n.id}/`}>
                <span class="note-card__date">{fmt.format(n.data.date)}</span>
                <span class="note-card__title">{n.data.title}</span>
                {n.data.summary && (
                  <span class="note-card__summary">{n.data.summary}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
