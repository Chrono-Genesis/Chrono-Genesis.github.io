---
import Base from "../layouts/Base.astro";

const roles = [
  {
    when: "Jun 2020 – present",
    title: "Principal Developer",
    org: "State of Colorado · Office of Information Technology",
    desc: "My current role is hands-on architecture for myColorado across iOS and Android. I set direction for a three-developer mobile team, mentor the developers beside me, and stay close enough to implementation to know where the design gets real. The work includes mDL and verifiable credentials, crash-free release gates, Kotlin Multiplatform, SwiftUI and Compose migration, CI/CD and release tooling, and the occasional backend-adjacent task when mobile depends on it.",
  },
  {
    when: "Mar 2019 – Apr 2020",
    title: "Mobile Engineer",
    org: "GetSwift",
    desc: "Worked on both native apps for a delivery scheduling, route optimization, and payments platform. The job was pragmatic mobile engineering: migrate Objective-C to Swift and Java to Kotlin while still shipping, handle App Store and Play Store submissions, localize for international markets including right-to-left layouts, and learn enough C#/.NET to unblock mobile features when backend changes were part of the work.",
  },
  {
    when: "Jan 2017 – Mar 2019",
    title: "Senior iOS Developer",
    org: "Verizon (via Matlen Silver)",
    desc: "Joined a 10-engineer iOS team on the prepaid product line of My Verizon. I worked through product-facing changes like the UI rebrand, dashboard, login, and onboarding, plus platform maintenance like Swift 3 to Swift 4, Face ID, iPhone X layouts, and NSOperation cleanup. That job changed how I think about shared conventions and review habits on a large app.",
  },
  {
    when: "2012 – 2016",
    title: "Earlier roles",
    org: "Project Roots · Soft Solutions · Eurisko",
    desc: "The early years were wider than mobile: JavaFX desktop work in D.C.; SQL queries, stored procedures, and database objects in Lebanon; BlackBerry and Android apps with REST/SOAP integration. That background still helps when a mobile issue crosses into data, APIs, or an unfamiliar backend.",
  },
];

const education = {
  when: "2010",
  title: "B.E., Computer & Communication Engineering",
  org: "Notre Dame University · Zouk Mosbeh, Lebanon",
};
---

<Base
  title="Experience"
  description="Marc Kayrouz's engineering path, from principal mobile architecture work at Colorado OIT back through native app and early backend-adjacent roles."
>
  <section class="wrap hero">
    <div class="hero__copy">
      <span class="eyebrow">Experience</span>
      <h1>Experience</h1>
      <p class="lede" style="margin-top: 1.25rem;">
        The short version of the path: state government mobile work now, delivery and telecom
        apps before that, and a few early roles that kept me close to databases and APIs.
      </p>
    </div>

    <aside class="hero__panel" aria-label="Experience summary">
      <span class="hero__panel-title">Snapshot</span>
      <ul class="hero__panel-list">
        <li>15+ years across native mobile and backend-adjacent systems</li>
        <li>Principal ownership of iOS and Android architecture for a state app</li>
        <li>Comfortable crossing stack boundaries when mobile work needs it</li>
      </ul>
    </aside>
  </section>

  <section class="wrap section section--panel">
    <ol class="timeline" aria-label="Roles">
      {
        roles.map((r) => (
          <li class="role">
            <div class="role__when">{r.when}</div>
            <div>
              <div class="role__title">{r.title}</div>
              <div class="role__org">{r.org}</div>
              <p class="role__desc">{r.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="wrap section">
    <span class="eyebrow">Education</span>
    <ol class="timeline">
      <li class="role">
        <div class="role__when">{education.when}</div>
        <div>
          <div class="role__title">{education.title}</div>
          <div class="role__org">{education.org}</div>
        </div>
      </li>
    </ol>
  </section>
</Base>
